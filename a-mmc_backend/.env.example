# Copy this file to .env and fill in values. Never commit .env to version control.

# Flask
SECRET_KEY=replace-me-with-a-random-string
FLASK_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ammc_dev
DB_USER=postgres
DB_PASSWORD=postgres

# JWT — generate a strong random value:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-me-with-a-strong-random-secret
# Access token lifetime in seconds (default: 3600 = 1 hour). TODO(security): tune per policy.
JWT_ACCESS_TOKEN_EXPIRES=3600
